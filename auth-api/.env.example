# JWT secrets — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change-me-generate-a-real-secret
JWT_REFRESH_SECRET=change-me-generate-a-real-secret

# Token lifetimes
ACCESS_TTL=15m
REFRESH_TTL=7d

# Your frontend URL (used for CORS and OAuth/SAML redirects)
WEB_URL=http://localhost:5173

# Set to "true" when behind HTTPS
COOKIE_SECURE=false

# First user to register with this email gets admin role automatically
ADMIN_EMAIL=

# Google OAuth (leave blank to keep google disabled in auth.config.json)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# SAML IdP cert (PEM block or base64, leave blank to keep saml disabled)
SAML_IDP_CERT=

# Email / SMTP (leave SMTP_HOST blank to print reset links to console in dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@yourcompany.com

# MongoDB connection
MONGO_URL=mongodb://localhost:27017/auth
